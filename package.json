        "@types/node": "^26.1.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.9.0",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.7.0",
        "eslint-plugin-vue": "^10.9.2",
        "npm-run-all2": "^9.0.2",
        "prettier": "^3.9.5",
        "typescript": "^6.0.3",
        "vite": "^8.1.4",
        "vue-tsc": "^3.3.7"
    },
    "type": "module"
